{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri/main/.schemas/tauri.config.schema.json",
  "productName": "JIABY POS",
  "version": "0.1.0",
  "identifier": "mg.jiaby.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JIABY POS",
        "width": 1024,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:pos-jiaby.db"
      }
    }
  }
}
